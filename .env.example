# Supabase (Dashboard → Project Settings → API)
# Der anon public key ist für den Browser gedacht, muss aber mit Row Level Security abgesichert sein.
# Niemals den service_role Key hier oder im Frontend verwenden.
#
# Vercel / lokal: dieselben VITE_* fürs Frontend (Vite ersetzt sie beim Build).
VITE_SUPABASE_URL=https://DEIN_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=

# SQL im Supabase SQL Editor (Reihenfolge):
# 1) supabase/migration_site_published_works.sql
# 2) supabase/migration_publish_supabase_rpc.sql
#
# Veröffentlichen läuft über RPC + Storage (kein Vercel-API-Key nötig).
# Optional: api/site-works.js (Service Role) ist veraltet und wird vom Frontend nicht mehr aufgerufen.
